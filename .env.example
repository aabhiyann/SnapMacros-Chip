# Supabase (required for meals and roast API when using DB)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URL (for email confirmation redirects in production)
# Set to your Vercel URL, e.g. https://snapmacros.vercel.app
NEXT_PUBLIC_APP_URL=

# Gemini (required for /api/analyze and /api/roast)
GOOGLE_AI_API_KEY=
